# Pulse Radio Environment Configuration
# Copy this file to .env.local and fill in values:
#   cp .env.example .env.local

# ─── Required for Production ────────────────────────────────────────

# Secures the /api/cron/sync endpoint to prevent unauthorized cache refresh.
# Generate with: openssl rand -hex 32
CRON_SECRET=

# ─── Optional ───────────────────────────────────────────────────────

# Bandsintown API key for concert/event data in /api/concerts.
# Falls back to a demo key (js_1dhsfh3t4) if not set.
BANDSINTOWN_APP_ID=

# ─── Feature Flags (all default to false when unset) ────────────────
# NEXT_PUBLIC_ERROR_REPORTING=true    # Enable client-side error reporting
# NEXT_PUBLIC_ANALYTICS=true          # Enable privacy-first analytics
# NEXT_PUBLIC_AUTH_ENABLED=true       # Enable user authentication / cloud sync
# NEXT_PUBLIC_DEBUG=true              # Enable debug mode (verbose logging)

# ─── Automatic (do not set manually) ────────────────────────────────

# NODE_ENV is set by Next.js automatically (development/production/test).
# npm_package_version is read from package.json at runtime.
